<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Account | ConnectSpace</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }
    </style>
</head>

<body class="bg-zinc-950 text-zinc-100 flex items-center justify-center min-h-screen p-4 md:p-8">
    <!-- Background subtle gradient glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-blue-900/20 via-zinc-950 to-zinc-950 -z-10"></div>

    <div class="w-full max-w-md bg-zinc-900/60 backdrop-blur-xl border border-zinc-800/80 rounded-2xl shadow-2xl p-8 transition-all duration-300 hover:border-zinc-700/80">
        <div class="mb-8 text-center">
            <h1 class="text-3xl font-bold tracking-tight text-white mb-2">ConnectSpace</h1>
            <p class="text-sm text-zinc-400">Join our developer network today</p>
        </div>

        <form action="/Register" method="post" class="space-y-5">
            <div>
                <label for="name" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-1.5">Full Name</label>
                <input 
                    id="name"
                    class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200" 
                    type="text" 
                    placeholder="John Doe" 
                    name="name" 
                    required
                >
            </div>

            <div>
                <label for="username" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-1.5">Username</label>
                <input 
                    id="username"
                    class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200" 
                    type="text" 
                    placeholder="johndoe" 
                    name="username" 
                    required
                >
            </div>

            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label for="age" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-1.5">Age</label>
                    <input 
                        id="age"
                        class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200" 
                        type="number" 
                        placeholder="25" 
                        name="age" 
                        required
                    >
                </div>
                <div>
                    <label for="email" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-1.5">Email Address</label>
                    <input 
                        id="email"
                        class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200" 
                        type="email" 
                        placeholder="john@example.com" 
                        name="email" 
                        required
                    >
                </div>
            </div>

            <div>
                <label for="password" class="block text-xs font-semibold uppercase tracking-wider text-zinc-400 mb-1.5">Password</label>
                <input 
                    id="password"
                    class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-lg text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200" 
                    type="password" 
                    placeholder="••••••••" 
                    name="password" 
                    required
                >
            </div>

            <button 
                type="submit" 
                class="w-full py-3 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-medium rounded-lg shadow-lg shadow-blue-600/20 transition-all duration-200 flex items-center justify-center cursor-pointer"
            >
                Create Account
            </button>
        </form>

        <div class="mt-8 text-center">
            <p class="text-sm text-zinc-400">
                Already have an account? 
                <a href="/login" class="text-blue-500 hover:text-blue-400 font-medium transition-all duration-200 hover:underline">Log in</a>
            </p>
        </div>
    </div>
</body>

</html>