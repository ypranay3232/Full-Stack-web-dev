<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard | ConnectSpace</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <style>
        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
        }
    </style>
</head>

<body class="bg-zinc-950 text-zinc-100 min-h-screen">
    <!-- Background subtle gradient glow -->
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_top,_var(--tw-gradient-stops))] from-blue-950/20 via-zinc-950 to-zinc-950 -z-10 pointer-events-none"></div>

    <!-- Navigation Header -->
    <header class="sticky top-0 z-40 w-full bg-zinc-950/80 backdrop-blur-md border-b border-zinc-900 px-6 py-4 flex justify-between items-center">
        <div class="flex items-center gap-3">
            <span class="text-xl font-bold tracking-tight text-white">ConnectSpace</span>
        </div>
        <div class="flex items-center gap-4">
            <span class="text-sm text-zinc-400 hidden sm:inline">Logged in as <span class="text-zinc-200 font-semibold">@<%= user.username %></span></span>
            <a href="/logout" class="px-4 py-2 bg-red-600/10 hover:bg-red-600/20 border border-red-500/20 hover:border-red-500/30 text-red-400 text-sm font-medium rounded-lg transition-all duration-200 cursor-pointer">
                Log Out
            </a>
        </div>
    </header>

    <!-- Main Container -->
    <main class="max-w-6xl mx-auto px-4 py-8 md:px-8 grid grid-cols-1 lg:grid-cols-12 gap-8">
        
        <!-- Left: Profile Widget -->
        <section class="lg:col-span-4 space-y-6">
            <div class="bg-zinc-900/40 backdrop-blur-md border border-zinc-800/80 rounded-2xl p-6 shadow-xl sticky top-24">
                <div class="flex items-center gap-4 mb-6">
                    <div class="w-16 h-16 rounded-full bg-blue-600/20 border-2 border-blue-500/30 flex items-center justify-center text-blue-400 font-bold text-2xl uppercase">
                        <%= user.name.charAt(0) %>
                    </div>
                    <div>
                        <h2 class="text-lg font-bold text-white"><%= user.name %></h2>
                        <p class="text-sm text-zinc-400">@<%= user.username %></p>
                    </div>
                </div>
                
                <div class="border-t border-zinc-800/80 my-4 pt-4 space-y-3">
                    <div class="flex justify-between text-sm">
                        <span class="text-zinc-400">Email</span>
                        <span class="text-zinc-200 font-medium truncate max-w-[180px]" title="<%= user.email %>"><%= user.email %></span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-zinc-400">Age</span>
                        <span class="text-zinc-200 font-medium"><%= user.age %> years</span>
                    </div>
                    <div class="flex justify-between text-sm">
                        <span class="text-zinc-400">Total Posts</span>
                        <span class="text-zinc-200 font-medium"><%= user.posts.length %></span>
                    </div>
                </div>
            </div>
        </section>

        <!-- Right: Feed and Creation -->
        <section class="lg:col-span-8 space-y-8">
            
            <!-- Create Post Card -->
            <div class="bg-zinc-900/40 backdrop-blur-md border border-zinc-800/80 rounded-2xl p-6 shadow-xl">
                <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 mb-4">Create a new post</h3>
                <form action="/post" method="post" class="space-y-4">
                    <textarea 
                        name="content" 
                        rows="3" 
                        placeholder="What's on your mind? Share an update, idea, or code snippet..."
                        class="w-full px-4 py-3 bg-zinc-900/40 border border-zinc-800 rounded-xl text-white placeholder-zinc-500 focus:outline-none focus:ring-2 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200 resize-none text-sm leading-relaxed"
                        required
                    ></textarea>
                    <div class="flex justify-end">
                        <button 
                            type="submit" 
                            class="px-5 py-2.5 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-medium text-sm rounded-lg shadow-lg shadow-blue-600/15 transition-all duration-200 cursor-pointer"
                        >
                            Publish Post
                        </button>
                    </div>
                </form>
            </div>

            <!-- Feed Section -->
            <div class="space-y-6">
                <div class="flex justify-between items-center border-b border-zinc-900 pb-2">
                    <h3 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">Recent Activity Feed</h3>
                    <span class="text-xs text-zinc-500"><%= posts.length %> posts total</span>
                </div>

                <% if (posts.length === 0) { %>
                    <!-- Empty State -->
                    <div class="bg-zinc-900/20 border border-dashed border-zinc-800/80 rounded-2xl p-12 text-center">
                        <p class="text-zinc-500 text-sm">No posts yet. Be the first to publish one!</p>
                    </div>
                <% } else { %>
                    <!-- Loop Posts -->
                    <% posts.forEach(post => { %>
                        <article class="bg-zinc-900/40 backdrop-blur-md border border-zinc-800/80 rounded-2xl p-6 shadow-lg space-y-4 transition-all duration-200 hover:border-zinc-700/80">
                            <!-- Post Header -->
                            <div class="flex justify-between items-start">
                                <div class="flex items-center gap-3">
                                    <div class="w-10 h-10 rounded-full bg-zinc-800 border border-zinc-700 flex items-center justify-center text-zinc-300 font-bold text-sm uppercase">
                                        <%= post.user ? post.user.name.charAt(0) : '?' %>
                                    </div>
                                    <div>
                                        <div class="flex items-center gap-1.5">
                                            <span class="text-sm font-bold text-white"><%= post.user ? post.user.name : 'Unknown User' %></span>
                                            <span class="text-xs text-zinc-500">@<%= post.user ? post.user.username : 'unknown' %></span>
                                        </div>
                                        <span class="text-[11px] text-zinc-500">
                                            <%= new Date(post.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                        </span>
                                    </div>
                                </div>

                                <!-- Actions dropdown (Edit/Delete) if post belongs to user -->
                                <% if (post.user && post.user._id.toString() === user._id.toString()) { %>
                                    <div class="flex items-center gap-2">
                                        <a href="/edit/<%= post._id %>" class="px-2.5 py-1 text-xs bg-zinc-800/60 hover:bg-zinc-800 border border-zinc-700 rounded-md text-zinc-300 hover:text-white transition-all cursor-pointer">
                                            Edit
                                        </a>
                                        <a href="/delete/<%= post._id %>" onclick="return confirm('Are you sure you want to delete this post?')" class="px-2.5 py-1 text-xs bg-red-950/20 hover:bg-red-950/40 border border-red-900/30 hover:border-red-900/50 rounded-md text-red-400 transition-all cursor-pointer">
                                            Delete
                                        </a>
                                    </div>
                                <% } %>
                            </div>

                            <!-- Post Content -->
                            <p class="text-sm text-zinc-200 leading-relaxed whitespace-pre-wrap"><%= post.content %></p>

                            <!-- Like button -->
                            <div class="flex items-center gap-4 pt-2 border-t border-zinc-900">
                                <a href="/like/<%= post._id %>" class="flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full transition-all cursor-pointer <%= post.likes.includes(user._id) ? 'bg-blue-600/10 text-blue-400 border border-blue-500/20' : 'bg-zinc-900/60 text-zinc-400 border border-zinc-800 hover:border-zinc-700' %>">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="<%= post.likes.includes(user._id) ? 'currentColor' : 'none' %>" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 10h4.764a2 2 0 011.789 2.894l-3.5 7A2 2 0 0115.263 21h-4.017c-.163 0-.326-.02-.485-.06L7 20m7-10V5a2 2 0 00-2-2h-.095c-.5 0-.905.405-.905.905 0 .714-.211 1.412-.608 2.006L7 11v9m7-10h-2M7 20H5a2 2 0 01-2-2v-6a2 2 0 012-2h2.5" />
                                    </svg>
                                    <span><%= post.likes.length %> <%= post.likes.length === 1 ? 'Like' : 'Likes' %></span>
                                </a>
                            </div>

                            <!-- Comments Section -->
                            <div class="bg-zinc-900/30 rounded-xl p-4 border border-zinc-800/40 space-y-3">
                                <span class="text-xs font-bold uppercase tracking-wider text-zinc-400 block">Comments</span>
                                
                                <!-- Comments List -->
                                <div class="space-y-2.5 max-h-48 overflow-y-auto pr-1">
                                    <% if (post.comments && post.comments.length > 0) { %>
                                        <% post.comments.forEach(comment => { %>
                                            <div class="text-xs bg-zinc-900/60 p-2.5 rounded-lg border border-zinc-900 flex flex-col gap-0.5">
                                                <div class="flex justify-between items-center">
                                                    <span class="font-bold text-zinc-300">@<%= comment.username %></span>
                                                    <span class="text-[10px] text-zinc-500">
                                                        <%= new Date(comment.createdAt).toLocaleDateString(undefined, { month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
                                                    </span>
                                                </div>
                                                <p class="text-zinc-200 mt-0.5"><%= comment.text %></p>
                                            </div>
                                        <% }) %>
                                    <% } else { %>
                                        <p class="text-zinc-500 text-xs italic">No comments yet.</p>
                                    <% } %>
                                </div>

                                <!-- Add Comment Form -->
                                <form action="/comment/<%= post._id %>" method="post" class="flex gap-2 pt-2 border-t border-zinc-900/40">
                                    <input 
                                        type="text" 
                                        name="text" 
                                        placeholder="Add a comment..."
                                        class="flex-1 px-3 py-1.5 bg-zinc-900/50 border border-zinc-800 rounded-lg text-xs text-white placeholder-zinc-500 focus:outline-none focus:ring-1 focus:ring-blue-500/50 focus:border-blue-500 transition-all duration-200"
                                        required
                                    >
                                    <button 
                                        type="submit" 
                                        class="px-3 py-1.5 bg-blue-600 hover:bg-blue-500 text-white font-medium text-xs rounded-lg transition-all cursor-pointer"
                                    >
                                        Post
                                    </button>
                                </form>
                            </div>
                        </article>
                    <% }) %>
                <% } %>
            </div>

        </section>

    </main>
</body>

</html>
