<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Task Details</title>
    <!-- im using tailwind cdn for quick setup rather than installing it entirely -->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    
    <div class="main w-full min-h-screen bg-zinc-900 text-white p-10">
        <a href="/" class="text-blue-500 mb-5 inline-block hover:text-blue-400 transition-colors">&larr; Back to Home</a>
        <h1 class="text-5xl mb-5 tracking-tight capitalize"><%= filename.replace('.txt', '') %></h1>
        <p class="text-zinc-300 text-lg bg-zinc-800 p-5 rounded-md min-h-50 whitespace-pre-wrap"><%= fileData %></p>
    </div>

</body>
</html>
