<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit User</title>
    <link rel="stylesheet" href="/stylesheets/style.css">
    <!-- Tailwind CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body>
    <div class="w-full min-h-screen bg-zinc-800 p-10  text-white">

        <!-- adding a nav to navigate between routes -->
         <div class="nav mb-10 ">
            <a href="/read" class="text-blue-500">Back to users</a>
         </div>

        <h1 class="text-3xl tracking-tighter mb-3">Update User</h1>
        <form action="/update/<%= user._id %>" method="post">
            <input class="px-5 py-2 bg-transparent outline-none border-2 border-zinc-500 rounded-lg" type="text"
                name="name" placeholder="name" value="<%= user.name %>">
            <input class="px-5 py-2 bg-transparent outline-none border-2 border-zinc-500 rounded-lg" type="email"
                name="email" placeholder="email" value="<%= user.email %>">
            <input class="px-5 py-2 bg-transparent outline-none border-2 border-zinc-500 rounded-lg" type="text"
                name="image" placeholder="Image Url" value="<%= user.image %>">
            <input class="px-5 py-2 bg-yellow-500 rounded-lg ml-3 text-black" type="submit" value="Update User">
        </form>
    </div>
</body>

</html>
