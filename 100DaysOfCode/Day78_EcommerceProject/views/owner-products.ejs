<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scatch Owner | All Products</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col justify-between">
    <!-- Navigation Bar -->
    <nav class="w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/shop" class="text-xl font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 font-bold">SCATCH OWNER</a>
            
            <div class="flex items-center gap-6">
                <a href="/shop" class="text-sm font-medium text-zinc-300 hover:text-white transition-all">Shop View</a>
                <a href="/owners/admin" class="text-sm font-medium text-zinc-300 hover:text-white transition-all">Create Product</a>
                <a href="/logout" class="text-xs font-semibold px-4 py-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:bg-zinc-800 hover:border-zinc-700 text-zinc-300 hover:text-white transition-all">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Content Grid -->
    <main class="w-full max-w-7xl mx-auto px-6 py-12 flex-1">
        <div class="mb-8">
            <span class="text-xs font-semibold uppercase tracking-widest text-blue-400">Inventory Management</span>
            <h2 class="text-3xl font-bold text-white mt-1">All Catalog Products</h2>
            <p class="text-xs text-zinc-500 mt-1">Manage and audit all items currently displayed in the shop.</p>
        </div>

        <% if (products.length === 0) { %>
            <div class="bg-zinc-900/20 border border-zinc-900 rounded-3xl p-16 text-center space-y-4">
                <p class="text-zinc-500">Your store has no products yet.</p>
                <a href="/owners/admin" class="inline-flex px-6 py-3 text-sm font-semibold bg-blue-600 hover:bg-blue-500 text-white rounded-xl shadow-lg shadow-blue-600/15 transition-all">
                    Add Your First Product
                </a>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
                <% products.forEach(function(product) { %>
                    <div class="group flex flex-col bg-zinc-900/30 border border-zinc-900 hover:border-zinc-800 rounded-2xl overflow-hidden shadow-lg transition-all duration-300">
                        
                        <!-- Canvas Image -->
                        <div class="w-full h-48 flex items-center justify-center p-5 relative transition-transform duration-300 group-hover:scale-[1.01]" style="background-color: <%= product.bgcolor %>;">
                            <img src="data:image/jpeg;base64,<%= product.image %>" class="h-32 object-contain drop-shadow-md">
                        </div>

                        <!-- Card Detail Panel -->
                        <div class="p-4 flex flex-col justify-between flex-1" style="background-color: <%= product.placeholder %>; color: <%= product.textcolor %>;">
                            <div>
                                <h4 class="font-bold text-sm tracking-tight truncate"><%= product.name %></h4>
                                <div class="flex items-center gap-2 mt-1">
                                    <span class="text-sm font-semibold">₹ <%= product.price - product.discount %></span>
                                    <% if (product.discount > 0) { %>
                                        <span class="text-xs line-through opacity-50">₹ <%= product.price %></span>
                                    <% } %>
                                </div>
                            </div>
                            
                            <div class="border-t border-zinc-800/10 mt-4 pt-3 flex justify-between items-center">
                                <span class="text-[10px] uppercase font-bold tracking-wider opacity-60">ID: ...<%= product._id.toString().slice(-6) %></span>
                                <a 
                                    href="/products/delete/<%= product._id %>" 
                                    class="text-xs font-semibold text-red-500 hover:text-red-400 hover:underline transition-all cursor-pointer"
                                    onclick="return confirm('Are you sure you want to delete this product?');"
                                >
                                    Delete
                                </a>
                            </div>
                        </div>

                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Success Toast Alert -->
    <% if (success && success.length > 0) { %>
        <div class="fixed bottom-6 right-6 z-50 animate-bounce">
            <div class="bg-blue-600/10 backdrop-blur-xl border border-blue-500/20 text-blue-400 px-6 py-3.5 rounded-xl shadow-2xl flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-blue-500 animate-ping"></span>
                <span class="text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>

    <!-- Footer -->
    <footer class="w-full border-t border-zinc-900 py-6 text-center text-xs text-zinc-600">
        &copy; 2026 Scatch Inc. All rights reserved.
    </footer>
</body>
</html>
