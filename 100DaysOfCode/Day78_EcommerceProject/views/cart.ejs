<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Scatch | My Cart</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        body {
            font-family: 'Outfit', sans-serif;
        }
    </style>
</head>
<body class="bg-zinc-950 text-zinc-100 min-h-screen flex flex-col justify-between">
    <!-- Navigation Bar -->
    <nav class="w-full border-b border-zinc-900 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
            <a href="/shop" class="text-xl font-bold tracking-wider text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400">SCATCH</a>
            
            <div class="flex items-center gap-6">
                <a href="/shop" class="text-sm font-medium text-zinc-300 hover:text-white transition-all">Shop</a>
                
                <a href="/users/cart" class="text-sm font-medium text-zinc-300 hover:text-white transition-all flex items-center gap-1.5 relative group">
                    Cart
                    <span class="px-2 py-0.5 text-[10px] font-bold rounded-full bg-blue-600 text-white min-w-5 h-5 flex items-center justify-center transition-all group-hover:bg-blue-500">
                        <%= user.cart.length %>
                    </span>
                </a>
                
                <a href="/logout" class="text-xs font-semibold px-4 py-2 bg-zinc-900 border border-zinc-800 rounded-xl hover:bg-zinc-800 hover:border-zinc-700 text-zinc-300 hover:text-white transition-all">
                    Logout
                </a>
            </div>
        </div>
    </nav>

    <!-- Main Cart Area -->
    <main class="w-full max-w-7xl mx-auto px-6 py-12 flex-1 flex flex-col lg:flex-row gap-10">
        
        <!-- Cart Items List (Left Side) -->
        <section class="flex-1 space-y-6">
            <h2 class="text-2xl font-bold text-white mb-6">Shopping Cart (<%= cartItems.length %> items)</h2>
            
            <% if (cartItems.length === 0) { %>
                <div class="bg-zinc-900/20 border border-zinc-900 rounded-3xl p-16 text-center space-y-4">
                    <p class="text-zinc-500">Your shopping cart is empty.</p>
                    <a href="/shop" class="inline-flex px-6 py-3 text-sm font-semibold bg-blue-600 hover:bg-blue-500 text-white rounded-xl shadow-lg shadow-blue-600/15 transition-all">
                        Continue Shopping
                    </a>
                </div>
            <% } else { %>
                <div class="space-y-4">
                    <% cartItems.forEach(function(item) { %>
                        <div class="flex flex-col sm:flex-row items-center justify-between bg-zinc-900/35 border border-zinc-900 p-5 rounded-2xl gap-5 hover:border-zinc-800 transition-all">
                            
                            <!-- Product thumbnail and details -->
                            <div class="flex flex-col sm:flex-row items-center gap-5 w-full sm:w-auto">
                                <div class="w-24 h-24 rounded-xl flex items-center justify-center p-3" style="background-color: <%= item.bgcolor %>;">
                                    <img src="data:image/jpeg;base64,<%= item.image %>" class="h-16 object-contain drop-shadow-md">
                                </div>
                                <div class="text-center sm:text-left">
                                    <h4 class="font-bold text-base text-white"><%= item.name %></h4>
                                    <p class="text-xs text-zinc-500 mt-1">Single item price: ₹ <%= item.price %></p>
                                    <% if (item.discount > 0) { %>
                                        <p class="text-[10px] font-bold text-red-500 uppercase tracking-wider mt-0.5">Discount: ₹ <%= item.discount %></p>
                                    <% } %>
                                </div>
                            </div>

                            <!-- Prices and Actions -->
                            <div class="flex items-center justify-between sm:justify-end gap-8 w-full sm:w-auto border-t sm:border-t-0 border-zinc-900 pt-4 sm:pt-0">
                                <div class="text-left sm:text-right">
                                    <span class="text-base font-bold text-white">₹ <%= item.price - item.discount %></span>
                                    <% if (item.discount > 0) { %>
                                        <span class="block text-xs line-through text-zinc-600">₹ <%= item.price %></span>
                                    <% } %>
                                </div>
                                <a href="/users/removefromcart/<%= item._id %>" class="px-4 py-2 text-xs font-semibold bg-red-600/10 hover:bg-red-600/20 text-red-400 rounded-xl border border-red-500/15 hover:border-red-500/25 transition-all cursor-pointer">
                                    Remove
                                </a>
                            </div>

                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>

        <!-- Invoice Billing Panel (Right Side) -->
        <% if (cartItems.length > 0) { %>
            <aside class="w-full lg:w-96">
                <div class="bg-zinc-900/35 border border-zinc-900 p-6 rounded-2xl space-y-6">
                    <h3 class="text-lg font-bold text-white">Price Details</h3>
                    
                    <div class="space-y-3.5 text-sm border-b border-zinc-900 pb-5">
                        <% 
                            let totalMRP = 0;
                            let totalDiscount = 0;
                            cartItems.forEach(item => {
                                totalMRP += item.price;
                                totalDiscount += item.discount;
                            });
                            let deliveryCharges = totalMRP > 0 ? 0 : 0; // free delivery
                            let finalPrice = totalMRP - totalDiscount + deliveryCharges;
                        %>
                        <div class="flex justify-between text-zinc-400">
                            <span>Price (MRP)</span>
                            <span>₹ <%= totalMRP %></span>
                        </div>
                        <div class="flex justify-between text-red-400">
                            <span>Discount on MRP</span>
                            <span>- ₹ <%= totalDiscount %></span>
                        </div>
                        <div class="flex justify-between text-zinc-400">
                            <span>Delivery Charges</span>
                            <span class="text-green-400 font-medium">FREE</span>
                        </div>
                    </div>

                    <div class="flex justify-between text-base font-bold text-white">
                        <span>Total Payable</span>
                        <span>₹ <%= finalPrice %></span>
                    </div>

                    <button class="w-full py-3.5 bg-blue-600 hover:bg-blue-500 active:bg-blue-700 text-white font-semibold rounded-xl shadow-lg shadow-blue-600/15 transition-all cursor-pointer">
                        Proceed to Payment
                    </button>
                </div>
            </aside>
        <% } %>

    </main>

    <!-- Success Toast Alert -->
    <% if (success && success.length > 0) { %>
        <div class="fixed bottom-6 right-6 z-50 animate-bounce">
            <div class="bg-blue-600/10 backdrop-blur-xl border border-blue-500/20 text-blue-400 px-6 py-3.5 rounded-xl shadow-2xl flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-blue-500 animate-ping"></span>
                <span class="text-sm font-medium"><%= success %></span>
            </div>
        </div>
    <% } %>

    <!-- Footer -->
    <footer class="w-full border-t border-zinc-900 py-6 text-center text-xs text-zinc-600">
        &copy; 2026 Scatch Inc. All rights reserved.
    </footer>
</body>
</html>
